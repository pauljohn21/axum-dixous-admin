/**app.wxss**/
page {
  /* 亮色主题 (默认) */
  --bg-color: #f0f2f5;
  --card-bg: #ffffff;
  --text-primary: #303133;
  --text-secondary: #909399;
  --text-placeholder: #c0c4cc;
  --border-color: #ebeef5;
  --border-light: #f2f6fc;
  --primary-color: #409eff;
  --primary-light: #a0cfff;
  --nav-bg: #409eff;
  --input-bg: #f5f7fa;
  --input-border: #e4e7ed;
  --success-color: #67c23a;
  --success-bg: #f0f9eb;
  --danger-color: #f56c6c;
  --danger-bg: #fef0f0;
  --warning-color: #e6a23c;
  --wechat-color: #07c160;
  --wechat-bg: #e8f8f0;
  --shadow: rgba(0, 0, 0, 0.08);
  --shadow-light: rgba(0, 0, 0, 0.04);

  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 暗色主题 */
page.dark {
  --bg-color: #1a1a2e;
  --card-bg: #16213e;
  --text-primary: #e0e0e0;
  --text-secondary: #909090;
  --text-placeholder: #505050;
  --border-color: #2a2a4a;
  --border-light: #202040;
  --primary-color: #409eff;
  --primary-light: #2a5a8a;
  --nav-bg: #16213e;
  --input-bg: #0f3460;
  --input-border: #2a2a4a;
  --success-color: #67c23a;
  --success-bg: #1a3a1a;
  --danger-color: #f56c6c;
  --danger-bg: #3a1a1a;
  --warning-color: #e6a23c;
  --wechat-color: #07c160;
  --wechat-bg: #1a3a2a;
  --shadow: rgba(0, 0, 0, 0.3);
  --shadow-light: rgba(0, 0, 0, 0.2);
}

/* 卡片 */
.card {
  background: var(--card-bg);
  border-radius: 12rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx var(--shadow);
}

/* 统计卡片 */
.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx;
}

.stat-value {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 按钮 */
.btn-primary {
  background: var(--primary-color);
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 0;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
}

.btn-primary[disabled] {
  background: var(--primary-light);
  color: #f4f4f5;
}

/* 输入框 */
.input-field {
  background: var(--input-bg);
  border: 1rpx solid var(--input-border);
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  color: var(--text-primary);
}

/* 列表项 */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.tag-success {
  background: var(--success-bg);
  color: var(--success-color);
}

.tag-danger {
  background: var(--danger-bg);
  color: var(--danger-color);
}

/* 文本工具类 */
.text-secondary {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.text-primary {
  color: var(--text-primary);
  font-size: 28rpx;
}

/* 卡片标题 */
.card-header {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: var(--text-secondary);
  font-size: 28rpx;
}

.info-value {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 500;
}

/* 空状态 */
.empty-state,
.loading-state,
.end-state {
  text-align: center;
  padding: 48rpx 0;
  color: var(--text-secondary);
  font-size: 26rpx;
}

/* 骨架屏动画 */
@keyframes skeleton-pulse {
  0% { opacity: 0.6; }
  50% { opacity: 0.3; }
  100% { opacity: 0.6; }
}

.skeleton-block {
  background: var(--border-color);
  border-radius: 8rpx;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}
