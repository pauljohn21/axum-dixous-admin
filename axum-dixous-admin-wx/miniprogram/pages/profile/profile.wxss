/* pages/profile/profile.wxss */
.profile-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 暗色主题变量覆盖 */
.profile-page.dark {
  --bg-color: #1a1a2e;
  --card-bg: #16213e;
  --text-primary: #e0e0e0;
  --text-secondary: #909090;
  --border-color: #2a2a4a;
  --border-light: #202040;
  --primary-color: #409eff;
  --input-bg: #0f3460;
  --input-border: #2a2a4a;
  --success-color: #67c23a;
  --danger-color: #f56c6c;
  --wechat-color: #07c160;
  --shadow: rgba(0, 0, 0, 0.3);
  --shadow-light: rgba(0, 0, 0, 0.2);
}

.user-card {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #409eff, #667eea);
  color: #ffffff;
}

.avatar-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.user-meta {
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
}

.user-nick {
  font-size: 26rpx;
  opacity: 0.8;
}

.card {
  margin: 24rpx 32rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx var(--shadow-light);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.arrow {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.text-success {
  color: var(--success-color) !important;
}

.text-warning {
  color: #e6a23c !important;
}

.password-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.input-field {
  border: 2rpx solid var(--input-border);
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  background: var(--card-bg);
}

.btn-primary {
  background: var(--primary-color) !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: 8rpx !important;
  font-size: 30rpx !important;
}

/* 微信绑定按钮 */
.btn-wx-bind {
  margin-top: 24rpx;
  background: #07c160 !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: 8rpx !important;
  font-size: 30rpx !important;
}

.btn-wx-bind[disabled] {
  opacity: 0.6;
}

.btn-wx-rebind {
  background: var(--text-secondary) !important;
}

.btn-logout {
  background: var(--danger-color) !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: 8rpx !important;
  font-size: 32rpx !important;
  width: 100% !important;
}

/* 主题切换 */
.theme-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.theme-switch {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.theme-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 导航入口 */
.nav-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.nav-item:last-child {
  border-bottom: none;
}

.nav-arrow {
  font-size: 28rpx;
  color: var(--text-placeholder);
}
