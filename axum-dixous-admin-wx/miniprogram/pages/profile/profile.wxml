<!--pages/profile/profile.wxml-->
<view class="profile-page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar-circle">
      <text>{{userInfo ? userInfo.username[0] : '?'}}</text>
    </view>
    <view class="user-meta">
      <text class="user-name">{{userInfo ? userInfo.username : '加载中...'}}</text>
      <text class="user-nick">{{userInfo ? (userInfo.nick_name || '未设置昵称') : ''}}</text>
    </view>
  </view>

  <!-- 基本信息卡片 -->
  <view class="card" wx:if="{{userInfo}}">
    <view class="card-header">基本信息</view>
    <view class="info-row">
      <text class="info-label">用户名</text>
      <text class="info-value">{{userInfo.username}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">昵称</text>
      <text class="info-value">{{userInfo.nick_name || '未设置'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">手机号</text>
      <text class="info-value">{{userInfo.phone || '未设置'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">邮箱</text>
      <text class="info-value">{{userInfo.email || '未设置'}}</text>
    </view>
  </view>

  <!-- 微信绑定 -->
  <view class="card" wx:if="{{userInfo}}">
    <view class="card-header">微信账号</view>
    <view class="info-row">
      <text class="info-label">绑定状态</text>
      <text class="info-value {{userInfo.wx_openid ? 'text-success' : 'text-warning'}}">
        {{userInfo.wx_openid ? '已绑定' : '未绑定'}}
      </text>
    </view>
    <button
      class="btn-wx-bind {{userInfo.wx_openid ? 'btn-wx-rebind' : ''}}"
      bindtap="bindWechat"
      loading="{{wxBinding}}"
      disabled="{{wxBinding}}"
    >
      {{wxBinding ? '处理中...' : (userInfo.wx_openid ? '重新绑定' : '绑定微信号')}}
    </button>
  </view>

  <!-- 修改密码 -->
  <view class="card">
    <view class="card-header" bindtap="togglePasswordForm">
      <text>修改密码</text>
      <text class="arrow">{{showPasswordForm ? '▲' : '▼'}}</text>
    </view>

    <view wx:if="{{showPasswordForm}}" class="password-form">
      <input
        class="input-field"
        placeholder="原密码"
        password="{{true}}"
        value="{{oldPassword}}"
        bindinput="onOldPasswordInput"
      />
      <input
        class="input-field"
        placeholder="新密码"
        password="{{true}}"
        value="{{newPassword}}"
        bindinput="onNewPasswordInput"
      />
      <input
        class="input-field"
        placeholder="确认新密码"
        password="{{true}}"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />
      <button class="btn-primary" bindtap="changePassword" style="margin-top: 24rpx;">
        确认修改
      </button>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="card">
    <button class="btn-logout" bindtap="doLogout">退出登录</button>
  </view>
</view>
