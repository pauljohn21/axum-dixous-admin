/* pages/dashboard/dashboard.wxss */
.dashboard {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 暗色主题变量覆盖 */
.dashboard.dark {
  --bg-color: #1a1a2e;
  --card-bg: #16213e;
  --text-primary: #e0e0e0;
  --text-secondary: #909090;
  --border-color: #2a2a4a;
  --border-light: #202040;
  --primary-color: #409eff;
  --input-bg: #0f3460;
  --input-border: #2a2a4a;
  --success-color: #67c23a;
  --success-bg: #1a3a1a;
  --danger-color: #f56c6c;
  --danger-bg: #3a1a1a;
  --shadow: rgba(0, 0, 0, 0.3);
  --shadow-light: rgba(0, 0, 0, 0.2);
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 24rpx;
}

.stats-grid .card {
  width: 48%;
  margin: 12rpx 0;
}

/* 骨架屏 */
.skeleton-stat {
  height: 120rpx;
  margin: 12rpx 0;
  width: 48%;
}

.skeleton-info-row {
  height: 60rpx;
  margin-bottom: 16rpx;
}
