/* pages/dashboard/dashboard.wxss */
.dashboard {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 24rpx;
}

.stats-grid .card {
  width: 48%;
  margin: 12rpx 0;
}

.card-header {
  font-size: 32rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #ebeef5;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2f6fc;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #909399;
  font-size: 28rpx;
}

.info-value {
  color: #303133;
  font-size: 28rpx;
  font-weight: 500;
}
