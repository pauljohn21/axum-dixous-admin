<!--pages/menus/menus.wxml-->
<view class="menus-page {{themeClass}}">
  <!-- 骨架屏 -->
  <view class="card" wx:if="{{loading}}">
    <view class="skeleton-menu" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
      <view class="skeleton-block skeleton-menu-line"></view>
    </view>
  </view>

  <!-- 菜单树 -->
  <view class="card" wx:if="{{!loading}}">
    <view class="card-header">菜单列表</view>

    <block wx:for="{{flatList}}" wx:key="id">
      <view class="menu-item" style="padding-left: {{32 + item.level * 40}}rpx;">
        <!-- 展开/折叠图标 -->
        <view class="menu-toggle" wx:if="{{item.children.length > 0}}" bindtap="onToggle" data-id="{{item.id}}">
          <text>{{item.collapsed ? '▶' : '▼'}}</text>
        </view>
        <view class="menu-toggle-placeholder" wx:else></view>

        <!-- 菜单内容 -->
        <view class="menu-content" bindtap="onMenuTap" data-id="{{item.id}}" hover-class="menu-hover">
          <text class="menu-name">{{item.name || '未命名'}}</text>
          <view class="menu-meta">
            <text wx:if="{{item.path}}" class="menu-path">{{item.path}}</text>
            <text wx:if="{{item.icon}}" class="menu-icon">{{item.icon}}</text>
            <text class="tag {{item.enable ? 'tag-success' : 'tag-danger'}}">{{item.enable ? '启用' : '禁用'}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:if="{{!loading && flatList.length === 0}}" class="empty-state">
      <text>暂无菜单数据</text>
    </view>
  </view>

  <!-- 详情弹窗 -->
  <view wx:if="{{showDetail}}" class="modal-mask" bindtap="onDetailClose">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">菜单详情</text>
        <text class="modal-close" bindtap="onDetailClose">✕</text>
      </view>

      <view class="info-row">
        <text class="info-label">名称</text>
        <text class="info-value">{{selectedMenu.name || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">路径</text>
        <text class="info-value">{{selectedMenu.path || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">组件</text>
        <text class="info-value">{{selectedMenu.component || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">图标</text>
        <text class="info-value">{{selectedMenu.icon || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">排序</text>
        <text class="info-value">{{selectedMenu.sort !== null ? selectedMenu.sort : '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">状态</text>
        <text class="info-value {{selectedMenu.enable ? 'text-success' : 'text-danger'}}">
          {{selectedMenu.enable ? '启用' : '禁用'}}
        </text>
      </view>
    </view>
  </view>
</view>
