/* pages/users/users.wxss */
.users-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 暗色主题变量覆盖 */
.users-page.dark {
  --bg-color: #1a1a2e;
  --card-bg: #16213e;
  --text-primary: #e0e0e0;
  --text-secondary: #909090;
  --border-color: #2a2a4a;
  --border-light: #202040;
  --primary-color: #409eff;
  --input-bg: #0f3460;
  --input-border: #2a2a4a;
  --success-color: #67c23a;
  --success-bg: #1a3a1a;
  --danger-color: #f56c6c;
  --danger-bg: #3a1a1a;
  --wechat-color: #07c160;
  --wechat-bg: #1a3a2a;
  --shadow: rgba(0, 0, 0, 0.3);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--card-bg);
}

.search-input {
  flex: 1;
  background: var(--input-bg);
  border: 1rpx solid var(--input-border);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-btn {
  background: var(--primary-color) !important;
  color: #ffffff !important;
  border: none !important;
  font-size: 24rpx !important;
  padding: 0 24rpx !important;
  line-height: 60rpx !important;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--primary-color);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.user-detail {
  font-size: 24rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-id {
  font-size: 24rpx;
  color: var(--text-placeholder);
  flex-shrink: 0;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

/* hover 效果 */
.list-item-hover {
  background: var(--border-light);
}

.empty-state,
.loading-state,
.end-state {
  text-align: center;
  padding: 48rpx 0;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.tag-success {
  background: var(--success-bg);
  color: var(--success-color);
}

.tag-danger {
  background: var(--danger-bg);
  color: var(--danger-color);
}

.tag-wechat {
  background: var(--wechat-bg);
  color: var(--wechat-color);
}

/* 骨架屏 */
.skeleton-user {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  gap: 24rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.skeleton-user-info {
  flex: 1;
}

.skeleton-line {
  height: 32rpx;
  margin-bottom: 12rpx;
}
