<!--pages/users/users.wxml-->
<view class="users-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索用户名/昵称/手机号"
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
    />
    <button class="search-btn" size="mini" bindtap="onSearch">搜索</button>
  </view>

  <!-- 用户列表 -->
  <view class="card">
    <block wx:for="{{users}}" wx:key="id">
      <view class="list-item">
        <!-- 头像 -->
        <view class="user-avatar">
          <text>{{item.username ? item.username[0] : '?'}}</text>
        </view>
        <!-- 信息 -->
        <view class="user-info">
          <view class="user-row">
            <text class="user-name">{{item.username}}</text>
            <text class="tag {{item.enable ? 'tag-success' : 'tag-danger'}}">{{item.enable ? '启用' : '禁用'}}</text>
            <text wx:if="{{item.wx_openid}}" class="tag tag-wechat">微信已绑</text>
          </view>
          <text class="user-detail">{{item.nick_name || '未设置昵称'}} · {{item.phone || '无手机号'}}</text>
          <text class="user-detail">{{item.email || '无邮箱'}}{{item.wx_openid ? ' · ' + item.wx_openid : ''}}</text>
        </view>
        <!-- ID -->
        <text class="user-id">#{{item.id}}</text>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:if="{{!loading && users.length === 0}}" class="empty-state">
      <text>暂无数据</text>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <text>加载中...</text>
    </view>

    <!-- 底部状态 -->
    <view wx:if="{{!loading && users.length > 0 && !hasMore}}" class="end-state">
      <text>共 {{total}} 条记录</text>
    </view>
  </view>
</view>
