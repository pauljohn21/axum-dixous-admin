/* pages/dicts/dicts.wxss */
.dicts-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 暗色主题变量覆盖 */
.dicts-page.dark {
  --bg-color: #1a1a2e;
  --card-bg: #16213e;
  --text-primary: #e0e0e0;
  --text-secondary: #909090;
  --text-placeholder: #505050;
  --border-color: #2a2a4a;
  --border-light: #202040;
  --primary-color: #409eff;
  --success-color: #67c23a;
  --success-bg: #1a3a1a;
  --danger-color: #f56c6c;
  --danger-bg: #3a1a1a;
  --shadow: rgba(0, 0, 0, 0.3);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--card-bg);
}

.search-input {
  flex: 1;
  background: var(--input-bg);
  border: 1rpx solid var(--input-border);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-btn {
  background: var(--primary-color) !important;
  color: #ffffff !important;
  border: none !important;
  font-size: 24rpx !important;
  padding: 0 24rpx !important;
  line-height: 60rpx !important;
}

.dict-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.dict-item:last-child {
  border-bottom: none;
}

.dict-hover {
  opacity: 0.6;
}

.dict-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.dict-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dict-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.dict-meta {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.dict-type {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-family: monospace;
}

.dict-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.dict-arrow {
  font-size: 32rpx;
  color: var(--text-placeholder);
  flex-shrink: 0;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.tag-success {
  background: var(--success-bg);
  color: var(--success-color);
}

.tag-danger {
  background: var(--danger-bg);
  color: var(--danger-color);
}

.text-success {
  color: var(--success-color) !important;
}

.text-danger {
  color: var(--danger-color) !important;
}

/* 骨架屏 */
.skeleton-dict {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.skeleton-dict-line {
  height: 32rpx;
  margin-bottom: 12rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.modal-content {
  width: 85%;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 40rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 32rpx;
  color: var(--text-secondary);
}
