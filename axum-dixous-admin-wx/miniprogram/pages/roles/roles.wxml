<!--pages/roles/roles.wxml-->
<view class="roles-page {{themeClass}}">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索角色名称"
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
    />
    <button class="search-btn" size="mini" bindtap="onSearch">搜索</button>
  </view>

  <!-- 角色列表 -->
  <view class="card">
    <!-- 骨架屏 -->
    <block wx:if="{{loading && roles.length === 0}}">
      <view class="skeleton-role" wx:for="{{[1,2,3,4]}}" wx:key="*this">
        <view class="skeleton-block skeleton-role-line"></view>
        <view class="skeleton-block skeleton-role-line" style="width: 50%;"></view>
      </view>
    </block>

    <!-- 角色数据 -->
    <block wx:if="{{!loading || roles.length > 0}}">
      <view class="role-item" wx:for="{{roles}}" wx:key="id">
        <view class="role-info">
          <view class="role-header">
            <text class="role-name">{{item.name || '未命名'}}</text>
            <text class="tag tag-keyword">{{item.keyword || ''}}</text>
          </view>
          <text class="role-desc">{{item.desc || '无描述'}}</text>
        </view>
        <view class="role-actions">
          <text class="action-btn edit" bindtap="onEdit" data-id="{{item.id}}">编辑</text>
          <text class="action-btn delete" bindtap="onDelete" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:if="{{!loading && roles.length === 0}}" class="empty-state">
      <text>暂无角色数据</text>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading && roles.length > 0}}" class="loading-state">
      <text>加载中...</text>
    </view>

    <!-- 底部状态 -->
    <view wx:if="{{!loading && roles.length > 0 && !hasMore}}" class="end-state">
      <text>共 {{total}} 条记录</text>
    </view>
  </view>

  <!-- 新增按钮 -->
  <view class="fab-btn" bindtap="onAdd">+</view>

  <!-- 新增/编辑弹窗 -->
  <view wx:if="{{showForm}}" class="modal-mask" bindtap="onFormClose">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{editingId ? '编辑角色' : '新增角色'}}</text>
        <text class="modal-close" bindtap="onFormClose">✕</text>
      </view>

      <view class="form-group">
        <text class="form-label">角色名称 *</text>
        <input class="input-field" placeholder="请输入角色名称" value="{{formName}}" bindinput="onFormNameInput" />
      </view>

      <view class="form-group">
        <text class="form-label">角色标识 *</text>
        <input class="input-field" placeholder="如: admin / editor" value="{{formKeyword}}" bindinput="onFormKeywordInput" />
      </view>

      <view class="form-group">
        <text class="form-label">描述</text>
        <input class="input-field" placeholder="可选" value="{{formDesc}}" bindinput="onFormDescInput" />
      </view>

      <view class="modal-footer">
        <button class="btn-cancel" bindtap="onFormClose">取消</button>
        <button class="btn-save" bindtap="onSave" loading="{{saving}}" disabled="{{saving}}">
          {{saving ? '保存中...' : '保存'}}
        </button>
      </view>
    </view>
  </view>
</view>
