/* pages/roles/roles.wxss */
.roles-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 暗色主题变量覆盖 */
.roles-page.dark {
  --bg-color: #1a1a2e;
  --card-bg: #16213e;
  --text-primary: #e0e0e0;
  --text-secondary: #909090;
  --text-placeholder: #505050;
  --border-color: #2a2a4a;
  --border-light: #202040;
  --primary-color: #409eff;
  --input-bg: #0f3460;
  --input-border: #2a2a4a;
  --danger-color: #f56c6c;
  --danger-bg: #3a1a1a;
  --shadow: rgba(0, 0, 0, 0.3);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--card-bg);
}

.search-input {
  flex: 1;
  background: var(--input-bg);
  border: 1rpx solid var(--input-border);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-btn {
  background: var(--primary-color) !important;
  color: #ffffff !important;
  border: none !important;
  font-size: 24rpx !important;
  padding: 0 24rpx !important;
  line-height: 60rpx !important;
}

/* 角色列表项 */
.role-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.role-item:last-child {
  border-bottom: none;
}

.role-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.role-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.role-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.role-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.tag-keyword {
  background: var(--border-light);
  color: var(--text-secondary);
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.role-actions {
  display: flex;
  gap: 24rpx;
  flex-shrink: 0;
}

.action-btn {
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}

.action-btn.edit {
  color: var(--primary-color);
}

.action-btn.delete {
  color: var(--danger-color);
}

/* 骨架屏 */
.skeleton-role {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.skeleton-role-line {
  height: 32rpx;
  margin-bottom: 12rpx;
}

/* 悬浮新增按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--primary-color);
  color: #ffffff;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(64, 158, 255, 0.4);
  z-index: 100;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.modal-content {
  width: 85%;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 40rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 32rpx;
  color: var(--text-secondary);
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.btn-cancel {
  flex: 1;
  background: var(--border-light) !important;
  color: var(--text-secondary) !important;
  border: none !important;
  border-radius: 8rpx !important;
  font-size: 30rpx !important;
}

.btn-save {
  flex: 1;
  background: var(--primary-color) !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: 8rpx !important;
  font-size: 30rpx !important;
}
